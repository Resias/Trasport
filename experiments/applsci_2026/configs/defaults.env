# Appl. Sci. 2026 default experiment settings.
# Source this file or let wrapper scripts use the same defaults.

DATA_ROOT=${DATA_ROOT:-data_splits/od_minute_review_3way}
TRAIN_SUBDIR=${TRAIN_SUBDIR:-train}
VAL_SUBDIR=${VAL_SUBDIR:-val}
TEST_SUBDIR=${TEST_SUBDIR:-test}

TIME_RESOLUTION=${TIME_RESOLUTION:-1}
WINDOW_SIZE=${WINDOW_SIZE:-60}
PRED_SIZE=${PRED_SIZE:-30}
HOP_SIZE=${HOP_SIZE:-10}

OD_CSV=${OD_CSV:-AD_matrix_trimmed_common.csv}
STATION_LATLON_CSV=${STATION_LATLON_CSV:-ad_station_latlon.csv}

METRO_GATF_BATCH_SIZE=${METRO_GATF_BATCH_SIZE:-2}
METRO_GATF_GAT_HEADS=${METRO_GATF_GAT_HEADS:-6}
METRO_GATF_GAT_HIDDEN=${METRO_GATF_GAT_HIDDEN:-64}
METRO_GATF_NODE_FEAT_DIM=${METRO_GATF_NODE_FEAT_DIM:-16}
METRO_GATF_DECODE_LAYERS=${METRO_GATF_DECODE_LAYERS:-2}
METRO_GATF_LR=${METRO_GATF_LR:-1e-4}
METRO_GATF_MAX_EPOCHS=${METRO_GATF_MAX_EPOCHS:-200}
METRO_GATF_GATE_TAU=${METRO_GATF_GATE_TAU:-0.9}
METRO_GATF_LAMBDA_GATE=${METRO_GATF_LAMBDA_GATE:-1.0}
METRO_GATF_POS_WEIGHT_CLIP=${METRO_GATF_POS_WEIGHT_CLIP:-10.0}

MAPE_EPS=${MAPE_EPS:-1e-3}
SEEDS=${SEEDS:-0,1,2}
